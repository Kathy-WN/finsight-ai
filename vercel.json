{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/landing.html",
      "dest": "/landing.html"
    },
    {
      "src": "/index.html",
      "dest": "/index.html"
    },
    {
      "src": "/analyze",
      "dest": "server.js"
    },
    {
      "src": "/",
      "dest": "/landing.html"
    }
  ]
}